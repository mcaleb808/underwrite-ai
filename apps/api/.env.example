# llm (all models via openrouter)
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=sk-xxx
STRONG_MODEL=anthropic/claude-sonnet-4.5
FAST_MODEL=openai/gpt-4o-mini

# database
DATABASE_URL=sqlite+aiosqlite:///./underwrite.db
CHROMA_DIR=./chroma_data
UPLOAD_DIR=./uploads

# cors
WEB_ORIGIN=http://localhost:3000

# email
# Use console for local dev (logs the rendered email). For real sends:
#   EMAIL_PROVIDER=resend, RESEND_API_KEY=re_xxx
# To bypass DMARC during testing, send from Resend's onboarding sender to
# the email you signed up to Resend with — no domain authentication needed.
EMAIL_PROVIDER=console
EMAIL_FROM=UnderwriteAI <onboarding@resend.dev>
EMAIL_REPLY_TO=underwriting@underwriteai.rw
INSURER_NAME=UnderwriteAI Demo Insurer
RESEND_API_KEY=re_xxx

# observability
LANGSMITH_API_KEY=ls_xxx
LANGSMITH_PROJECT=underwrite-ai
LOG_LEVEL=INFO
